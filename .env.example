# Database Configuration
# PostgreSQL connection string with asyncpg driver
DATABASE_URL=postgresql+asyncpg://rforum:rforum@db:5432/rforum

# Redis Configuration
# Redis URL for real-time pub/sub and caching
REDIS_URL=redis://redis:6379/0

# JWT Configuration
# Secret key for signing JWT tokens (generate a strong random string for production)
SECRET_KEY=change-me-to-a-random-secret-in-production

# JWT Algorithm (HS256 is recommended)
ALGORITHM=HS256

# Session token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS Configuration
# List of allowed origins for CORS requests (JSON array format)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:8000"]

# Authentication Configuration
# Invite code required for user registration
INVITE_CODE=RFORUM01

# Super Admin Configuration
# Email of user to be promoted to super admin on first registration (optional)
# Leave empty to disable auto-promotion
SUPER_ADMIN_EMAIL=

# File Upload Configuration
# Maximum file upload size in MB
UPLOAD_MAX_MB=20

# Allowed file extensions for uploads (comma-separated if using .env)
# Supported: .pdf, .ppt, .pptx, .doc, .docx, .txt, .odp, .odt
UPLOAD_ALLOWED_EXTENSIONS=.pdf,.ppt,.pptx,.doc,.docx,.txt,.odp,.odt
